#!/bin/bash -eux

{{if .Debug}}
trap 'echo "DEBUG: error at line $LINENO" >&2; sleep 300' ERR
{{else}}
trap 'sudo /sbin/poweroff' ERR EXIT
{{end}}

if [[ -n "{{.SSHKey}}" ]]; then
  mkdir -p /root/.ssh
  echo "{{.SSHKey}}" | tee -a /root/.ssh/authorized_keys
  chage -d "$(date +%Y-%m-%d)" root 2>/dev/null || true
fi

# Phase 1: Start cloudblockdev (NBD → R2) early so the block device
# initializes while we install packages.
modprobe nbd

ARCH=$(dpkg --print-architecture)
case "$ARCH" in
  amd64) CBD_ARCH=amd64 ;;
  arm64) CBD_ARCH=arm64 ;;
  *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
esac

CBD_URL="https://github.com/anupcshan/cloudblockdev/releases/download/1772439544-6ebe4db/cloudblockdev-linux-${CBD_ARCH}"
curl -fsSL "$CBD_URL" -o /usr/local/bin/cloudblockdev
chmod +x /usr/local/bin/cloudblockdev

mkdir -p /etc/cloudblockdev
cat > /etc/cloudblockdev/config.yaml <<CBDCONFIG
device:
  size: {{.VolumeSize}}

s3:
  bucket: {{.R2Bucket}}
  endpoint: {{.R2Endpoint}}
  access_key: {{.R2AccessKeyID}}
  secret_key: {{.R2SecretAccessKey}}
  region: auto

server:
  listen: ""

nbd:
  enabled: true
  index: 0
  dead_conn_timeout: 120s
CBDCONFIG

/usr/local/bin/cloudblockdev serve -config /etc/cloudblockdev/config.yaml &
CBD_PID=$!

# Phase 2: Install tailscale + ZFS while cloudblockdev starts up.
curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/noble.noarmor.gpg | sudo tee /usr/share/keyrings/tailscale-archive-keyring.gpg >/dev/null
curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/noble.tailscale-keyring.list | sudo tee /etc/apt/sources.list.d/tailscale.list

sudo apt-get update -o Dir::Etc::sourcelist="sources.list.d/tailscale.list" \
  -o Dir::Etc::sourceparts="-" -o APT::Get::List-Cleanup="0"

sudo apt-get install -y --no-install-recommends tailscale jq curl zfsutils-linux || {
  sudo sed -i 's/Components:.*/Components: main/' /etc/apt/sources.list.d/*.sources 2>/dev/null || true
  sudo sed -i 's/ universe//g; s/ multiverse//g; s/ restricted//g' /etc/apt/sources.list 2>/dev/null || true
  sudo sed -i '/^deb/ { /main/!d }' /etc/apt/sources.list 2>/dev/null || true
  sudo apt-get update
  sudo apt-get install -y --no-install-recommends tailscale jq curl zfsutils-linux
}

modprobe zfs

sudo sed -i 's/FLAGS=""/FLAGS="--state=mem: --verbose=1"/' /etc/default/tailscaled
sudo systemctl restart tailscaled.service

timeout 5m sudo tailscale up --accept-routes {{.Args}}

set +x

# Wait for tailscale IP
TS_IP=$(tailscale ip -4)
while ! ip addr show dev tailscale0 2>/dev/null | grep -q "$TS_IP"; do
  sleep 1
done

# Phase 3: Wait for cloudblockdev NBD device, then import or create ZFS pool.
echo "Waiting for /dev/nbd0 ..."
timeout 120 bash -c 'while [ ! -b /dev/nbd0 ]; do sleep 1; done'

# Try importing existing pool first (data survives across VM lifecycles).
# -f handles the case where the previous VM didn't cleanly export.
if ! zpool import -f data 2>/dev/null; then
  echo "No existing pool found, creating new ZFS pool on /dev/nbd0"
  zpool create -f -o ashift=12 -O mountpoint=/data -O atime=off -O compression=lz4 data /dev/nbd0
fi

# Ensure /data is the mountpoint
zfs set mountpoint=/data data 2>/dev/null || true

# Phase 4: Download filebrowser and run on persistent /data.
FB_ARCH=$ARCH
FB_VERSION="2.31.2"
FB_URL="https://github.com/filebrowser/filebrowser/releases/download/v${FB_VERSION}/linux-${FB_ARCH}-filebrowser.tar.gz"

cd /opt
curl -fsSL "$FB_URL" | tar xz
chmod +x /opt/filebrowser

# Store filebrowser database on the persistent volume so settings survive.
# config init fails if the DB already exists, so ignore errors.
/opt/filebrowser config init --address "$TS_IP" --port 80 --root /data --database /data/.filebrowser.db 2>/dev/null || true
# Update bind address (may have changed between VM lifecycles).
/opt/filebrowser config set --address "$TS_IP" --port 80 --database /data/.filebrowser.db
# Add default user only if none exist yet.
USER_COUNT=$(/opt/filebrowser users ls --database /data/.filebrowser.db 2>/dev/null | tail -n +2 | wc -l)
if [ "$USER_COUNT" -eq 0 ]; then
  /opt/filebrowser users add admin adminadminadmin --database /data/.filebrowser.db
fi

/opt/filebrowser --database /data/.filebrowser.db &
FB_PID=$!

# Phase 5: Stats/identity endpoint on port 8245.
mkdir -p /tmp/stats
echo "{\"last_active\": $(date +%s)}" > /tmp/stats/stats.json

cat > /tmp/stats/identity.json <<IDENTITY
{"service": "{{.Service}}", "provider": "{{.Provider}}", "region": "{{.Region}}", "name": "{{.InstanceName}}"}
IDENTITY

(cd /tmp/stats && python3 -m http.server 8245 --bind "$TS_IP") &

# Track activity via TCP connections to port 80
lastActiveTime=$(date "+%s")

while sleep 30; do
  now=$(date "+%s")

  activeConns=$(ss -tn state established '( sport = :80 )' 2>/dev/null | tail -n +2 | wc -l)
  if [ "$activeConns" -gt 0 ]; then
    lastActiveTime=$now
  fi

  # Check if cloudblockdev and filebrowser are still running
  if ! kill -0 $CBD_PID 2>/dev/null; then
    echo "cloudblockdev exited unexpectedly" >&2
    exit 1
  fi
  if ! kill -0 $FB_PID 2>/dev/null; then
    echo "filebrowser exited unexpectedly" >&2
    exit 1
  fi

  echo "{\"last_active\": $lastActiveTime}" > /tmp/stats/stats.json.tmp
  mv /tmp/stats/stats.json.tmp /tmp/stats/stats.json
done
