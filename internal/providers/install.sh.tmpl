#!/bin/bash -eux

{{if .Debug}}
trap 'echo "DEBUG: error at line $LINENO" >&2; sleep 300' ERR
{{else}}
trap 'sudo /sbin/poweroff' ERR EXIT
{{end}}

if [[ -n "{{.SSHKey}}" ]]; then
  mkdir -p /root/.ssh
  echo "{{.SSHKey}}" | tee -a /root/.ssh/authorized_keys
  # Some providers (e.g. DigitalOcean) force a root password change on
  # first login, which blocks even key-auth SSH sessions. Clear it.
  chage -d "$(date +%Y-%m-%d)" root 2>/dev/null || true
fi

curl -fsSL https://pkgs.tailscale.com/stable/debian/bookworm.noarmor.gpg | sudo tee /usr/share/keyrings/tailscale-archive-keyring.gpg >/dev/null
curl -fsSL https://pkgs.tailscale.com/stable/debian/bookworm.tailscale-keyring.list | sudo tee /etc/apt/sources.list.d/tailscale.list

sudo apt-get update
sudo apt-get install -y --no-install-recommends tailscale jq curl

echo 'net.ipv4.ip_forward = 1' | sudo tee -a /etc/sysctl.d/99-tailscale.conf
echo 'net.ipv6.conf.all.forwarding = 1' | sudo tee -a /etc/sysctl.d/99-tailscale.conf
sudo sysctl -p /etc/sysctl.d/99-tailscale.conf

sudo sed -i 's/FLAGS=""/FLAGS="--state=mem: --verbose=1"/' /etc/default/tailscaled
sudo systemctl restart tailscaled.service

timeout 5m sudo tailscale up --accept-routes --advertise-exit-node --advertise-connector {{.Args}}

set +x

# Track forwarded traffic for last-active reporting.
# ForwDatagrams in /proc/net/snmp counts only IP-forwarded packets (exit node
# traffic), not locally-terminated control traffic or health-check pings.
lastForwarded=$(awk '/^Ip:/ && !/Forwarding/ {print $7}' /proc/net/snmp)
lastForwardedTime=$(date "+%s")

# Serve stats over HTTP on port 8245 for the control plane to poll.
# Port 80 is left free for the actual service (filebrowser, Jupyter, etc.).
# We avoid `tailscale serve` because it uses HTTPS, which registers
# certificates in Certificate Transparency logs and leaks node hostnames.
mkdir -p /tmp/stats
echo "{\"forwarded_bytes\": 0, \"last_active\": $(date +%s)}" > /tmp/stats/stats.json

# Write static identity file at boot (provider/region/service for discovery).
cat > /tmp/stats/identity.json <<IDENTITY
{"service": "{{.Service}}", "provider": "{{.Provider}}", "region": "{{.Region}}"}
IDENTITY

# Wait for tailscale IP to be assignable on the interface before binding.
TS_IP=$(tailscale ip -4)
while ! ip addr show dev tailscale0 2>/dev/null | grep -q "$TS_IP"; do
  sleep 1
done
(cd /tmp/stats && python3 -m http.server 8245 --bind "$TS_IP") &

# Update stats file every 30 seconds
while sleep 30; do
  currentForwarded=$(awk '/^Ip:/ && !/Forwarding/ {print $7}' /proc/net/snmp)
  now=$(date "+%s")
  if [ "$currentForwarded" != "$lastForwarded" ]; then
    lastForwarded=$currentForwarded
    lastForwardedTime=$now
  fi

  # Forwarded bytes from the iptables ts-forward chain
  fwdBytes=$(iptables -L FORWARD -v -n -x 2>/dev/null | awk '/ts-forward/ {print $2}')
  fwdBytes=${fwdBytes:-0}

  # Atomic write via rename
  echo "{\"forwarded_bytes\": $fwdBytes, \"last_active\": $lastForwardedTime}" > /tmp/stats/stats.json.tmp
  mv /tmp/stats/stats.json.tmp /tmp/stats/stats.json
done
