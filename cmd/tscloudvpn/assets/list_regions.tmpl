{{ template "header.tmpl" . }}

<!-- Active Nodes -->
<section>
  <h2>Active Nodes</h2>
  <div id="nodes-list" sse-swap="running-nodes-table">
    <div class="no-nodes">No active nodes</div>
  </div>
</section>

<!-- Service Tabs + Region Picker -->
<section>
  <h2>Launch Node</h2>
  <div class="service-tabs">
    {{ range $i, $svc := .Services }}
    <button class="service-tab{{ if eq $i 0 }} active{{ end }}" onclick="switchTab('{{ $svc.Name }}', this)">{{ $svc.Label }}</button>
    {{ end }}
  </div>
  <div class="search-wrap">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input id="search" type="text" placeholder="Filter regions..." autocomplete="off">
  </div>
  {{ range $i, $svc := .Services }}
  <div class="service-panel" id="panel-{{ $svc.Name }}" {{ if ne $i 0 }}style="display:none"{{ end }}>
    {{ if $svc.NamedInstances }}
    <!-- Named instance form -->
    <div class="named-form" id="form-{{ $svc.Name }}">
      <div class="form-row">
        <input type="text" class="form-input" id="name-{{ $svc.Name }}" placeholder="Instance name (e.g. photos, docs)" autocomplete="off">
        <select class="form-select" id="provider-{{ $svc.Name }}" onchange="updateRegions('{{ $svc.Name }}')">
          {{ range $svc.Providers }}
          <option value="{{ .Name }}">{{ .Label }}</option>
          {{ end }}
        </select>
        <select class="form-select" id="region-{{ $svc.Name }}">
        </select>
        <button class="btn btn-create" onclick="createNamedInstance('{{ $svc.Name }}')">Create</button>
      </div>
    </div>
    {{ else }}
    <!-- Region picker -->
    <div class="providers">
      {{ range groupByProvider $svc.Regions }}
      <div class="provider-group" data-provider="{{ .Provider }}">
        <div class="provider-header" onclick="toggleProvider(this)">
          <span class="provider-name">{{ .Label }}</span>
          <span class="provider-count">{{ len .Regions }} region{{ if ne (len .Regions) 1 }}s{{ end }}</span>
          <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </div>
        <div class="provider-body">
          {{ range .Regions }}
          <div class="region-row" data-name="{{ .LongName }}">
            <span class="region-name">{{ .LongName }}</span>
            <span class="region-price">{{ printf "%.2f" .PriceCentsPerHour }}c/hr</span>
            <span class="region-status" sse-swap="{{ .Service }}-{{ .Provider }}-{{ .Region }}-hasnode"></span>
            <span class="region-action" sse-swap="{{ .Service }}-{{ .Provider }}-{{ .Region }}-button"></span>
          </div>
          {{ end }}
        </div>
      </div>
      {{ end }}
    </div>
    <div class="empty" style="display:none">No regions match your search.</div>
    {{ end }}
  </div>
  {{ end }}
</section>

<script>
function toggleProvider(header) {
  header.classList.toggle('open');
  header.nextElementSibling.classList.toggle('open');
}

function switchTab(serviceName, btn) {
  document.querySelectorAll('.service-tab').forEach(function(t) { t.classList.remove('active'); });
  btn.classList.add('active');
  document.querySelectorAll('.service-panel').forEach(function(p) { p.style.display = 'none'; });
  document.getElementById('panel-' + serviceName).style.display = '';
  // Clear search when switching tabs
  var search = document.getElementById('search');
  search.value = '';
  search.dispatchEvent(new Event('input'));
}

document.getElementById('search').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  // Only filter the visible panel
  var activePanel = document.querySelector('.service-panel[style=""], .service-panel:not([style*="display: none"]):not([style*="display:none"])');
  if (!activePanel) return;

  var anyVisible = false;

  activePanel.querySelectorAll('.provider-group').forEach(function(group) {
    var rows = group.querySelectorAll('.region-row');
    var visibleCount = 0;

    rows.forEach(function(row) {
      var name = row.getAttribute('data-name').toLowerCase();
      var provider = group.getAttribute('data-provider').toLowerCase();
      var match = !q || name.indexOf(q) > -1 || provider.indexOf(q) > -1;
      row.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    group.style.display = visibleCount > 0 ? '' : 'none';
    if (visibleCount > 0) anyVisible = true;

    var header = group.querySelector('.provider-header');
    var body = group.querySelector('.provider-body');
    if (q.length > 0 && visibleCount > 0) {
      header.classList.add('open');
      body.classList.add('open');
    } else if (q.length === 0) {
      header.classList.remove('open');
      body.classList.remove('open');
    }

    group.querySelector('.provider-count').textContent =
      visibleCount + ' region' + (visibleCount !== 1 ? 's' : '');
  });

  activePanel.querySelector('.empty').style.display = anyVisible ? 'none' : 'block';
});

// Region data for named instance dropdowns
var regionData = {
  {{ range $svc := .Services }}{{ if $svc.NamedInstances }}{{ range $svc.Providers }}
  "{{ $svc.Name }}-{{ .Name }}": [{{ range .Regions }}{"code":"{{ .Code }}","name":"{{ .LongName }}"},{{ end }}],
  {{ end }}{{ end }}{{ end }}
};

function updateRegions(svc) {
  var provider = document.getElementById('provider-' + svc).value;
  var sel = document.getElementById('region-' + svc);
  var regions = regionData[svc + '-' + provider] || [];
  sel.innerHTML = '';
  regions.forEach(function(r) {
    var opt = document.createElement('option');
    opt.value = r.code;
    opt.textContent = r.name;
    sel.appendChild(opt);
  });
}

function createNamedInstance(svc) {
  var name = document.getElementById('name-' + svc).value.trim();
  if (!name) { alert('Please enter an instance name'); return; }
  if (!/^[a-z0-9]([a-z0-9-]*[a-z0-9])?$/.test(name)) {
    alert('Name must be lowercase letters, numbers, and hyphens (no leading/trailing hyphens)');
    return;
  }
  var provider = document.getElementById('provider-' + svc).value;
  var region = document.getElementById('region-' + svc).value;
  var url = '/services/' + svc + '/instances/' + name + '/providers/' + provider + '/regions/' + region;
  fetch(url, {method: 'PUT'}).then(function(r) {
    if (!r.ok) r.text().then(function(t) { alert('Error: ' + t); });
  });
}

// Initialize region dropdowns for named services
{{ range .Services }}{{ if .NamedInstances }}
updateRegions('{{ .Name }}');
{{ end }}{{ end }}
</script>

{{ template "footer.tmpl" . }}
