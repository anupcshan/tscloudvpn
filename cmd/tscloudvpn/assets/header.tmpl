<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TSCloudVPN</title>

  <script src="/assets/htmx.org@1.9.12/htmx.min.js"></script>
  <script src="/assets/htmx.org@1.9.12/ext/disable-element.js"></script>
  <script src="/assets/htmx.org@1.9.12/ext/sse.js"></script>

  <style>
    :root {
      --bg: #0e0e10;
      --surface: #18181c;
      --border: #2a2a30;
      --accent: #4ade80;
      --accent-dim: rgba(74,222,128,0.12);
      --text: #e4e4e7;
      --muted: #71717a;
      --danger: #f87171;
      --danger-dim: rgba(248,113,113,0.1);
      --warning: #fbbf24;
      --info: #60a5fa;
      --info-dim: rgba(96,165,250,0.1);
      --mono: ui-monospace, 'SF Mono', 'Cascadia Mono', 'Segoe UI Mono', 'DejaVu Sans Mono', Menlo, Consolas, monospace;
      --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 14px;
      min-height: 100vh;
    }

    /* -- Header -- */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      gap: 12px;
      flex-wrap: wrap;
    }

    .wordmark {
      font-family: var(--mono);
      font-size: 15px;
      font-weight: 500;
      color: white;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
    }

    .wordmark:hover { opacity: 0.9; }

    .wordmark svg { width: 18px; height: 18px; }

    .stats {
      display: flex;
      gap: 20px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
    }

    .stat strong {
      color: var(--text);
      font-weight: 500;
      display: block;
      font-size: 15px;
      line-height: 1;
      margin-bottom: 2px;
    }

    /* -- Main layout -- */
    main { padding: 20px; max-width: 900px; margin: 0 auto; }

    section { margin-bottom: 32px; }

    h2 {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }

    /* -- Running nodes -- */
    .node-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 6px;
      padding: 12px 16px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 16px;
      align-items: center;
      margin-bottom: 8px;
    }

    .node-card-launching {
      border-left-color: var(--info);
    }

    .node-card-failed {
      border-left-color: var(--danger);
    }

    .node-card-failed .node-meta span {
      white-space: normal;
      overflow-wrap: break-word;
    }

    .node-main {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .node-location {
      font-size: 15px;
      font-weight: 500;
      color: var(--text);
    }

    .node-service {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      background: var(--accent-dim);
      padding: 2px 6px;
      border-radius: 3px;
    }

    .node-provider {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      background: var(--border);
      padding: 2px 6px;
      border-radius: 3px;
    }

    .node-meta {
      display: flex;
      gap: 16px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      flex-wrap: wrap;
    }

    .node-meta span { white-space: nowrap; }
    .node-meta .val { color: var(--text); }

    .pill {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 999px;
      font-family: var(--mono);
      font-size: 10px;
      font-weight: 500;
    }

    .pill-green { background: var(--accent-dim); color: var(--accent); }
    .pill-yellow { background: rgba(251,191,36,0.1); color: var(--warning); }
    .pill-blue { background: var(--info-dim); color: var(--info); }
    .pill-red { background: var(--danger-dim); color: var(--danger); }

    /* -- Buttons -- */
    .btn {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      padding: 6px 12px;
      border-radius: 4px;
      border: none;
      cursor: pointer;
      transition: opacity 0.15s;
      white-space: nowrap;
      text-decoration: none;
      display: inline-block;
    }

    .btn:hover { opacity: 0.8; }

    .btn-danger {
      background: var(--danger-dim);
      color: var(--danger);
      border: 1px solid rgba(248,113,113,0.2);
    }

    .btn-create {
      background: var(--accent-dim);
      color: var(--accent);
      border: 1px solid rgba(74,222,128,0.2);
      padding: 5px 12px;
    }

    .btn-create:disabled, .btn-danger:disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }

    /* -- Search -- */
    .search-wrap {
      position: relative;
      margin-bottom: 12px;
    }

    .search-wrap svg {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      pointer-events: none;
    }

    #search {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      padding: 9px 12px 9px 34px;
      border-radius: 6px;
      outline: none;
      transition: border-color 0.15s;
    }

    #search::placeholder { color: var(--muted); }
    #search:focus { border-color: var(--accent); }

    /* -- Provider groups -- */
    .provider-group { margin-bottom: 4px; }

    .provider-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: pointer;
      user-select: none;
      transition: border-color 0.15s;
    }

    .provider-header:hover { border-color: #3a3a44; }
    .provider-header.open { border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-bottom-color: transparent; }

    .provider-name {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      color: var(--text);
      flex: 1;
    }

    .provider-count {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
    }

    .chevron {
      color: var(--muted);
      transition: transform 0.2s;
      flex-shrink: 0;
    }

    .provider-header.open .chevron { transform: rotate(180deg); }

    .provider-body {
      display: none;
      border: 1px solid var(--border);
      border-top: none;
      border-bottom-left-radius: 6px;
      border-bottom-right-radius: 6px;
      overflow: hidden;
    }

    .provider-body.open { display: block; }

    .region-row {
      display: flex;
      align-items: center;
      padding: 9px 12px;
      border-bottom: 1px solid var(--border);
      gap: 10px;
      transition: background 0.1s;
    }

    .region-row:last-child { border-bottom: none; }
    .region-row:hover { background: var(--surface); }

    .region-name {
      flex: 1;
      font-size: 13px;
      color: var(--text);
    }

    .region-price {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      min-width: 48px;
      text-align: right;
    }

    .no-nodes {
      color: var(--muted);
      font-size: 13px;
      font-style: italic;
      padding: 8px 0;
    }

    .empty {
      padding: 32px;
      text-align: center;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 12px;
    }

    .region-status {
      min-width: 60px;
      text-align: right;
    }

    .region-action {
      min-width: 60px;
      text-align: right;
    }
  </style>
</head>
<body hx-ext="sse" sse-connect="/events">

<header>
  <a href="/" class="wordmark">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
      <ellipse cx="4" cy="12" rx="3" ry="3" fill="white" opacity="0.3"/>
      <ellipse cx="12" cy="12" rx="3" ry="3" fill="white" opacity="0.3"/>
      <ellipse cx="4" cy="20" rx="3" ry="3" fill="white" opacity="0.8"/>
      <ellipse cx="20" cy="20" rx="3" ry="3" fill="white" opacity="0.8"/>
      <ellipse cx="12" cy="20" rx="3" ry="3" fill="white" opacity="0.3"/>
      <ellipse cx="20" cy="12" rx="3" ry="3" fill="white" opacity="0.3"/>
      <ellipse cx="4" cy="4" rx="3" ry="3" fill="white" opacity="0.8"/>
      <ellipse cx="12" cy="4" rx="3" ry="3" fill="white" opacity="0.3"/>
      <ellipse cx="20" cy="4" rx="3" ry="3" fill="white" opacity="0.8"/>
      <path d="M 4 12 L 12 4 L 20 12 L 12 20 Z" fill="transparent" stroke="white" stroke-width="2" opacity="0.4"/>
      <path d="M 4 12 L 20 12" fill="transparent" stroke="white" stroke-width="2" opacity="0.9"/>
      <path d="M 12 4 L 12 20" fill="transparent" stroke="white" stroke-width="2" opacity="0.9"/>
    </svg>
    tscloudvpn
  </a>
  <div class="stats">
    <div class="stat"><strong sse-swap="provider-count">{{ .ProviderCount }}</strong>providers</div>
    <div class="stat"><strong sse-swap="region-count">{{ .RegionCount }}</strong>regions</div>
    <div class="stat"><strong sse-swap="active-nodes">{{ .ActiveNodes }}</strong>active</div>
  </div>
</header>

<main>
